      "seed": 288305354,
      "version": 201,
      "versionNonce": 1178255306,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783455242466,
      "link": null,
      "locked": false,
      "text": "Chunking Strategies",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Chunking Strategies",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "TFyEBrxHedqrtQgtIHVsJ",
      "type": "text",
      "x": -379.4035601080076,
      "y": 983.2719773792638,
      "width": 462.1917156538598,
      "height": 230.75757113370037,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aH",
      "roundness": null,
      "seed": 1889644374,
      "version": 262,
      "versionNonce": 897899094,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783455243018,
      "link": null,
      "locked": false,
      "text": "Problem Faced:\nChunks PAGE BY PAGE instead of merging all pages into one giant string.\n\n    Why: the previous approach merged everything into one stream, then tried\n    to re-find each chunk's text inside that stream to recover its page\n    number. That fails because LangChain's splitters rewrite whitespace when\n    reconstructing page_content (collapsing \"\\\\n\\\\n\" into \"  \\\\n\", etc.), so\n    chunk_text never byte-matches the original stream and .find() returns -1\n    every time -- silently defaulting every chunk to page 1.\n\n    Chunking per page sidesteps the problem entirely: we always know which\n    page we're processing, because we're never out of that page's scope.\n    The only thing we lose is letting a section span cleanly across a page\n    break without a chunk boundary there too -- an acceptable tradeoff for\n    correct metadata, and noted below if you want to revisit it later.",
      "fontSize": 12.30707046046403,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Problem Faced:\nChunks PAGE BY PAGE instead of merging all pages into one giant string.\n\n    Why: the previous approach merged everything into one stream, then tried\n    to re-find each chunk's text inside that stream to recover its page\n    number. That fails because LangChain's splitters rewrite whitespace when\n    reconstructing page_content (collapsing \"\\\\n\\\\n\" into \"  \\\\n\", etc.), so\n    chunk_text never byte-matches the original stream and .find() returns -1\n    every time -- silently defaulting every chunk to page 1.\n\n    Chunking per page sidesteps the problem entirely: we always know which\n    page we're processing, because we're never out of that page's scope.\n    The only thing we lose is letting a section span cleanly across a page\n    break without a chunk boundary there too -- an acceptable tradeoff for\n    correct metadata, and noted below if you want to revisit it later.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "IVwlj2PAfZ26brOnZLLqy",
      "type": "text",
      "x": 113.72186713808634,
      "y": 1008.7265505770621,
      "width": 172.65274047851562,
      "height": 82.2222345525567,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
