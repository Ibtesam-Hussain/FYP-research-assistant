      "isDeleted": false,
      "boundElements": null,
      "updated": 1783455243018,
      "link": null,
      "locked": false,
      "text": ". custom page-aware, \n. heading-aware,\n. fixed-size chunking\n. overlapping windows",
      "fontSize": 16.44444691051134,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": ". custom page-aware, \n. heading-aware,\n. fixed-size chunking\n. overlapping windows",
