    {
      "id": "5UsefUQogfYR8Bp3N_alo",
      "type": "text",
      "x": -30.96287587616274,
      "y": 939.0295901278433,
      "width": 192.3998260498047,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
